# Zero Hunger Connect — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/zerohunger

# JWT secret key — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Backend server port (do not change — frontend proxy is configured for 8000)
PORT=8000
